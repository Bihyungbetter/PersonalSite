---
/**
 * Project card with a live auto-rotating 3D viewer. The viewer is a pure
 * turntable (data-interactive="false"): the canvas ignores the pointer, so
 * the whole card stays a plain link and wheel-scrolling never zooms.
 * The poster paints instantly; the shared Three.js chunk swaps it out.
 */
interface Props {
  href: string;
  title: string;
  summary: string;
  model?: string;
  poster?: string;
  up?: "y" | "z";
}

const { href, title, summary, model, poster, up = "y" } = Astro.props;
---

<a href={href} class="group block h-full outline-none">
  <div
    class="flex h-full flex-col overflow-hidden rounded-xl bg-card ring-1 ring-foreground/10 transition-all group-hover:ring-brand/50 group-focus-visible:ring-2 group-focus-visible:ring-ring"
  >
    <div
      class="relative aspect-[16/11] w-full select-none"
      data-model-src={model}
      data-up={up}
      data-interactive="false"
    >
      <div data-viewer-poster class="absolute inset-0">
        {
          poster ? (
            <img
              src={poster}
              alt={`${title} preview`}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover"
            />
          ) : (
            <div
              aria-hidden="true"
              class="flex h-full w-full items-center justify-center [background-image:linear-gradient(to_right,--theme(--color-border/40%)_1px,transparent_1px),linear-gradient(to_bottom,--theme(--color-border/40%)_1px,transparent_1px)] [background-size:32px_32px]"
            >
              <span class="font-mono text-3xl text-muted-foreground/50">{title.slice(0, 1)}</span>
            </div>
          )
        }
      </div>
    </div>

    <div class="flex flex-1 flex-col gap-2 p-5">
      <h3 class="flex items-center gap-2 font-semibold">
        {title}
        {
          model && (
            <span class="rounded-full px-2 py-0.5 font-mono text-[10px] tracking-wide text-brand ring-1 ring-brand/30 ring-inset">
              3D
            </span>
          )
        }
      </h3>
      <p class="line-clamp-2 text-sm text-muted-foreground">{summary}</p>
    </div>
  </div>
</a>

<script>
  // Load the shared viewer chunk and start every turntable on the page.
  for (const container of document.querySelectorAll<HTMLElement>("[data-model-src]")) {
    import("@/lib/viewer").then(({ createViewer }) => createViewer(container));
  }
</script>
