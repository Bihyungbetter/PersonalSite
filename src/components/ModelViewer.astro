---
/**
 * Two-stage 3D viewer island.
 * Stage 1 (this markup): a static poster/placeholder — zero JS cost.
 * Stage 2: the small script below lazy-imports the Three.js viewer on tap,
 * or automatically when scrolled into view on fast connections.
 */
interface Props {
  src: string;
  poster?: string;
  alt?: string;
}

const { src, poster, alt = "3D model preview" } = Astro.props;
---

<div
  class="model-viewer group relative aspect-[4/3] w-full overflow-hidden rounded-xl bg-card ring-1 ring-foreground/10 select-none sm:aspect-[16/9]"
  data-model-src={src}
>
  <div data-viewer-poster class="absolute inset-0">
    {
      poster ? (
        <img src={poster} alt={alt} class="h-full w-full object-cover" decoding="async" />
      ) : (
        <div
          aria-hidden="true"
          class="h-full w-full [background-image:linear-gradient(to_right,--theme(--color-border/40%)_1px,transparent_1px),linear-gradient(to_bottom,--theme(--color-border/40%)_1px,transparent_1px)] [background-size:32px_32px]"
        />
      )
    }
    <button
      type="button"
      data-viewer-load
      class="absolute inset-0 flex h-full w-full cursor-pointer flex-col items-center justify-center gap-3 bg-background/40 transition-colors hover:bg-background/20"
    >
      <span
        class="flex items-center gap-2 rounded-full border border-border bg-background/90 px-4 py-2 text-sm font-medium shadow-sm"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"
          ></path>
          <path d="m3.3 7 8.7 5 8.7-5"></path>
          <path d="M12 22V12"></path>
        </svg>
        View in 3D
      </span>
      <span class="text-xs text-muted-foreground">Drag to orbit · scroll to zoom</span>
    </button>
  </div>

  <div
    data-viewer-progress
    hidden
    class="absolute inset-x-0 bottom-0 z-10 p-3 text-center text-xs text-muted-foreground"
  >
    <div class="mx-auto h-1 w-2/3 overflow-hidden rounded-full bg-muted">
      <div
        data-viewer-progress-bar
        class="h-full w-0 rounded-full bg-foreground/70 transition-[width] duration-200"
      >
      </div>
    </div>
  </div>

  <div data-viewer-controls hidden class="absolute right-2 bottom-2 z-10 flex gap-1.5">
    <button
      type="button"
      data-viewer-reset
      class="rounded-md border border-border bg-background/80 px-2.5 py-1.5 text-xs font-medium backdrop-blur transition-colors hover:bg-muted"
    >
      Reset view
    </button>
    <button
      type="button"
      data-viewer-fullscreen
      class="rounded-md border border-border bg-background/80 px-2.5 py-1.5 text-xs font-medium backdrop-blur transition-colors hover:bg-muted"
    >
      Fullscreen
    </button>
  </div>
</div>

<script>
  const containers = document.querySelectorAll<HTMLElement>("[data-model-src]");

  for (const container of containers) {
    let loaded = false;
    const load = async () => {
      if (loaded) return;
      loaded = true;
      const { createViewer } = await import("@/lib/viewer");
      createViewer(container);
    };

    container.querySelector("[data-viewer-load]")?.addEventListener("click", load);

    // Auto-load when scrolled into view, but only on fast connections that
    // haven't asked to save data. On slow/metered networks the user taps.
    const connection = (
      navigator as Navigator & {
        connection?: { effectiveType?: string; saveData?: boolean };
      }
    ).connection;
    const fast =
      !connection || (connection.effectiveType === "4g" && !connection.saveData);
    if (fast) {
      new IntersectionObserver(
        (entries, observer) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            observer.disconnect();
            load();
          }
        },
        { rootMargin: "80px" },
      ).observe(container);
    }
  }
</script>
