---
/**
 * 3D viewer island. The poster/placeholder paints instantly as static HTML;
 * the small script below then lazy-imports the Three.js viewer chunk right
 * away, which replaces the poster once the model is ready and auto-rotates
 * until the visitor grabs it.
 */
interface Props {
  src: string;
  poster?: string;
  alt?: string;
  /** CAD exports are usually Z-up; glTF is Y-up. Set "z" to stand the model upright. */
  up?: "y" | "z";
}

const { src, poster, alt = "3D model preview", up = "y" } = Astro.props;
---

<div
  class="model-viewer group relative aspect-[4/3] w-full overflow-hidden rounded-xl bg-card ring-1 ring-foreground/10 select-none sm:aspect-[16/9]"
  data-model-src={src}
  data-up={up}
>
  <div data-viewer-poster class="absolute inset-0">
    {
      poster ? (
        <img src={poster} alt={alt} class="h-full w-full object-cover" decoding="async" />
      ) : (
        <div
          aria-hidden="true"
          class="h-full w-full [background-image:linear-gradient(to_right,--theme(--color-border/40%)_1px,transparent_1px),linear-gradient(to_bottom,--theme(--color-border/40%)_1px,transparent_1px)] [background-size:32px_32px]"
        />
      )
    }
  </div>

  <div
    data-viewer-progress
    hidden
    class="absolute inset-x-0 bottom-0 z-10 p-3 text-center text-xs text-muted-foreground"
  >
    <div class="mx-auto h-1 w-2/3 overflow-hidden rounded-full bg-muted">
      <div
        data-viewer-progress-bar
        class="h-full w-0 rounded-full bg-foreground/70 transition-[width] duration-200"
      >
      </div>
    </div>
  </div>

  <div data-viewer-controls hidden class="absolute inset-x-2 bottom-2 z-10 flex items-end justify-between gap-2">
    <span class="px-1 text-xs text-muted-foreground/80">Drag to orbit · scroll to zoom</span>
    <div class="flex gap-1.5">
      <button
        type="button"
        data-viewer-reset
        class="rounded-md border border-border bg-background/80 px-2.5 py-1.5 text-xs font-medium backdrop-blur transition-colors hover:bg-muted"
      >
        Reset view
      </button>
      <button
        type="button"
        data-viewer-fullscreen
        class="rounded-md border border-border bg-background/80 px-2.5 py-1.5 text-xs font-medium backdrop-blur transition-colors hover:bg-muted"
      >
        Fullscreen
      </button>
    </div>
  </div>
</div>

<script>
  // Load the viewer immediately — the poster keeps the page painting fast while
  // the (cached, code-split) Three.js chunk and model stream in.
  for (const container of document.querySelectorAll<HTMLElement>("[data-model-src]")) {
    import("@/lib/viewer").then(({ createViewer }) => createViewer(container));
  }
</script>
