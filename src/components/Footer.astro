---
import { site } from "@/lib/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-border/60">
  <div
    class="mx-auto flex w-full max-w-5xl flex-col items-center justify-between gap-2 px-4 py-6 text-sm text-muted-foreground sm:flex-row sm:px-6"
  >
    <p>© {year} {site.name}</p>
    <p>
      <a href={`mailto:${site.email}`} class="transition-colors hover:text-foreground">
        {site.email}
      </a>
    </p>
  </div>
</footer>
