---
/**
 * CAD crosshair cursor: a hairline reticle with an amber center dot chases
 * the pointer, and corner brackets snap around links/buttons like a CAD
 * selection box. Vanilla JS, fine-pointer devices only, respects reduced
 * motion, and the rAF loop stops whenever the reticle settles.
 */
---

<div id="cursor" aria-hidden="true">
  <svg width="44" height="44" viewBox="0 0 44 44" style="display:block">
    <g stroke="var(--muted-foreground)" stroke-opacity="0.55" stroke-width="1">
      <line x1="22" y1="0" x2="22" y2="15"></line>
      <line x1="22" y1="29" x2="22" y2="44"></line>
      <line x1="0" y1="22" x2="15" y2="22"></line>
      <line x1="29" y1="22" x2="44" y2="22"></line>
    </g>
    <circle cx="22" cy="22" r="2.5" fill="var(--brand)"></circle>
  </svg>
</div>
<div id="cursor-brackets" aria-hidden="true">
  <i></i><i></i><i></i><i></i>
</div>

<script>
  (() => {
    if (
      !matchMedia("(hover: hover) and (pointer: fine)").matches ||
      matchMedia("(prefers-reduced-motion: reduce)").matches
    )
      return;

    const el = document.getElementById("cursor");
    const svg = el?.querySelector("svg");
    const brackets = document.getElementById("cursor-brackets");
    if (!el || !svg || !brackets) return;

    let tx = -100,
      ty = -100,
      x = tx,
      y = ty,
      scale = 1,
      targetScale = 1,
      running = false,
      rafId = 0,
      shown = false;
    let target: Element | null = null;

    function frame() {
      x += (tx - x) * 0.3;
      y += (ty - y) * 0.3;
      scale += (targetScale - scale) * 0.25;
      el!.style.transform = `translate(${x - 22}px, ${y - 22}px)`;
      svg!.style.transform = `scale(${scale})`;
      const settled = Math.abs(tx - x) < 0.2 && Math.abs(ty - y) < 0.2 &&
        Math.abs(targetScale - scale) < 0.01;
      if (settled) {
        running = false;
        return;
      }
      rafId = requestAnimationFrame(frame);
    }
    function wake() {
      if (!running) {
        running = true;
        rafId = requestAnimationFrame(frame);
      }
    }

    function frameBrackets() {
      if (!target || !target.isConnected) return;
      const pad = 6;
      const r = target.getBoundingClientRect();
      brackets!.style.left = `${r.left - pad}px`;
      brackets!.style.top = `${r.top - pad}px`;
      brackets!.style.width = `${r.width + pad * 2}px`;
      brackets!.style.height = `${r.height + pad * 2}px`;
    }

    window.addEventListener(
      "mousemove",
      (e) => {
        tx = e.clientX;
        ty = e.clientY;
        if (!shown) {
          shown = true;
          x = tx;
          y = ty;
          document.documentElement.classList.add("custom-cursor");
        }
        wake();
      },
      { passive: true },
    );
    document.addEventListener("mouseover", (e) => {
      const t = e.target instanceof Element && e.target.closest("a, button, [role=button]");
      if (t === target) return;
      target = t || null;
      if (target) {
        frameBrackets();
        brackets.classList.add("on");
      } else {
        brackets.classList.remove("on");
      }
    });
    // Keep brackets glued to the hovered element while the page scrolls.
    window.addEventListener("scroll", () => target && frameBrackets(), { passive: true });
    window.addEventListener("mousedown", () => {
      targetScale = 0.8;
      wake();
    });
    window.addEventListener("mouseup", () => {
      targetScale = 1;
      wake();
    });
    document.documentElement.addEventListener("mouseleave", () => {
      document.documentElement.classList.remove("custom-cursor");
      brackets.classList.remove("on");
      target = null;
      shown = false;
    });
    window.addEventListener("pagehide", () => cancelAnimationFrame(rafId));
  })();
</script>
