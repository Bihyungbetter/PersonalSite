---
/**
 * Dot + ring cursor: a small amber dot tracks the pointer exactly while a
 * springy ring trails behind and expands around links/buttons. Vanilla JS,
 * fine-pointer devices only, respects reduced motion, and the rAF loop
 * stops whenever the ring settles.
 */
---

<div id="cursor-dot" aria-hidden="true"></div>
<div id="cursor-ring" aria-hidden="true"></div>

<script>
  (() => {
    if (
      !matchMedia("(hover: hover) and (pointer: fine)").matches ||
      matchMedia("(prefers-reduced-motion: reduce)").matches
    )
      return;

    const dot = document.getElementById("cursor-dot");
    const ring = document.getElementById("cursor-ring");
    if (!dot || !ring) return;

    let tx = -100,
      ty = -100,
      x = tx,
      y = ty,
      scale = 1,
      targetScale = 1,
      running = false,
      rafId = 0,
      shown = false;

    function frame() {
      x += (tx - x) * 0.22;
      y += (ty - y) * 0.22;
      scale += (targetScale - scale) * 0.25;
      ring!.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
      const settled =
        Math.abs(tx - x) < 0.2 && Math.abs(ty - y) < 0.2 &&
        Math.abs(targetScale - scale) < 0.01;
      if (settled) {
        running = false;
        return;
      }
      rafId = requestAnimationFrame(frame);
    }
    function wake() {
      if (!running) {
        running = true;
        rafId = requestAnimationFrame(frame);
      }
    }

    window.addEventListener(
      "mousemove",
      (e) => {
        tx = e.clientX;
        ty = e.clientY;
        dot.style.transform = `translate(${tx}px, ${ty}px)`;
        if (!shown) {
          shown = true;
          x = tx;
          y = ty;
          document.documentElement.classList.add("custom-cursor");
        }
        wake();
      },
      { passive: true },
    );
    document.addEventListener("mouseover", (e) => {
      const t = e.target instanceof Element && e.target.closest("a, button, [role=button]");
      ring.classList.toggle("link", !!t);
    });
    window.addEventListener("mousedown", () => {
      targetScale = 0.85;
      wake();
    });
    window.addEventListener("mouseup", () => {
      targetScale = 1;
      wake();
    });

    const reset = () => {
      document.documentElement.classList.remove("custom-cursor");
      ring.classList.remove("link");
      targetScale = 1;
      scale = 1;
      shown = false;
    };
    document.documentElement.addEventListener("mouseleave", reset);
    // Navigating away (e.g. opening the resume PDF) and coming back via the
    // back button restores this page from the bfcache with all cursor state
    // intact — clear it on both pagehide and pageshow so nothing is left
    // stuck on screen until the next mousemove.
    window.addEventListener("pagehide", () => {
      reset();
      cancelAnimationFrame(rafId);
      running = false;
    });
    window.addEventListener("pageshow", reset);
  })();
</script>
