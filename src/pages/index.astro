---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import { ProjectCard } from "@/components/ProjectCard";
import { buttonVariants } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import GitHub from "@/components/icons/GitHub.astro";
import LinkedIn from "@/components/icons/LinkedIn.astro";
import Mail from "@/components/icons/Mail.astro";
import FileText from "@/components/icons/FileText.astro";
import { site } from "@/lib/site";

const projects = (await getCollection("projects")).sort(
  (a, b) =>
    Number(b.data.featured) - Number(a.data.featured) ||
    b.data.date.valueOf() - a.data.date.valueOf(),
);

// Roles cycled by the hero typewriter.
const roles = ["biped robots", "flight sim hardware", "custom macropads", "things that move"];
---

<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Engineering-grid backdrop: fine + major CAD gridlines, pure CSS, zero JS -->
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 [mask-image:radial-gradient(ellipse_85%_90%_at_50%_0%,black,transparent_78%)]"
    >
      <div
        class="absolute inset-0 [background-image:linear-gradient(to_right,--theme(--color-foreground/5%)_1px,transparent_1px),linear-gradient(to_bottom,--theme(--color-foreground/5%)_1px,transparent_1px)] [background-size:24px_24px]"
      >
      </div>
      <div
        class="absolute inset-0 [background-image:linear-gradient(to_right,--theme(--color-foreground/8%)_1px,transparent_1px),linear-gradient(to_bottom,--theme(--color-foreground/8%)_1px,transparent_1px)] [background-size:120px_120px]"
      >
      </div>
      <div
        class="absolute inset-0 [background:radial-gradient(ellipse_55%_45%_at_72%_-10%,--theme(--color-brand/9%),transparent)]"
      >
      </div>
    </div>

    <div class="mx-auto w-full max-w-5xl px-4 pt-24 pb-20 sm:px-6 sm:pt-36 sm:pb-28">
      <p class="font-mono text-sm tracking-widest text-muted-foreground uppercase">
        {site.role}
      </p>
      <h1 class="mt-3 text-5xl font-bold tracking-tight text-balance sm:text-7xl">
        {site.name}
      </h1>
      <p class="mt-5 font-mono text-lg sm:text-xl">
        <span class="text-muted-foreground">designing&nbsp;</span><span id="typed" class="text-brand"
          >{roles[0]}</span
        >
      </p>
      <script is:inline define:vars={{ roles }}>
        // Cycle through roles with a typewriter effect (reduced-motion safe:
        // the first role is already in the static HTML).
        (() => {
          const el = document.getElementById("typed");
          if (!el || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          let word = 0;
          let len = el.textContent.length;
          // The first word is fully typed in the static HTML, so begin by deleting it.
          let deleting = true;
          const tick = () => {
            const text = roles[word];
            len += deleting ? -1 : 1;
            el.textContent = text.slice(0, len);
            let delay = deleting ? 45 : 75;
            if (!deleting && len === text.length) {
              delay = 2200;
              deleting = true;
            } else if (deleting && len === 0) {
              deleting = false;
              word = (word + 1) % roles.length;
              delay = 350;
            }
            setTimeout(tick, delay);
          };
          setTimeout(tick, 2200);
        })();
      </script>
      <div class="mt-8 flex items-center gap-1">
        {
          site.github && (
            <a
              href={site.github}
              rel="noopener"
              aria-label="GitHub"
              class="rounded-md p-2.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            >
              <GitHub class="size-5" />
            </a>
          )
        }
        {
          site.linkedin && (
            <a
              href={site.linkedin}
              rel="noopener"
              aria-label="LinkedIn"
              class="rounded-md p-2.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            >
              <LinkedIn class="size-5" />
            </a>
          )
        }
        <a
          href={`mailto:${site.email}`}
          aria-label="Email"
          class="rounded-md p-2.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
        >
          <Mail class="size-5" />
        </a>
        {
          site.resume && (
            <a
              href={site.resume}
              aria-label="Resume"
              class="rounded-md p-2.5 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
            >
              <FileText class="size-5" />
            </a>
          )
        }
      </div>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="#projects" class={buttonVariants()}>View projects</a>
        <a href={`mailto:${site.email}`} class={buttonVariants({ variant: "outline" })}>
          <Mail />
          Get in touch
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6">
    <h2
      class="flex items-center gap-3 font-mono text-sm tracking-widest text-muted-foreground uppercase"
    >
      <span aria-hidden="true" class="h-px w-8 bg-brand"></span>About
    </h2>
    <div class="mt-4 max-w-2xl space-y-4 leading-7 text-foreground/90">
      <p>
        I spend most of my time designing mechanisms and hardware — from robotics
        drivetrain components to input devices. Everything on this site was modeled in
        CAD, and most projects include an interactive 3D view of the real assembly.
      </p>
      <p>
        <!-- TODO: personalize this section -->
        Tools I reach for: Onshape and Fusion 360 for mechanical design, KiCad for
        electronics, and a 3D printer for everything in between.
      </p>
    </div>
  </section>

  <Separator className="mx-auto max-w-5xl" />

  <!-- Projects -->
  <section id="projects" class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6">
    <h2
      class="flex items-center gap-3 font-mono text-sm tracking-widest text-muted-foreground uppercase"
    >
      <span aria-hidden="true" class="h-px w-8 bg-brand"></span>Projects
    </h2>
    <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map(({ id, data }) => (
          <ProjectCard
            href={`/projects/${id}/`}
            title={data.title}
            summary={data.summary}
            tags={data.tags}
            poster={data.poster}
            hasModel={Boolean(data.model)}
          />
        ))
      }
    </div>
  </section>

  <Separator className="mx-auto max-w-5xl" />

  <!-- Contact -->
  <section id="contact" class="mx-auto w-full max-w-5xl px-4 py-16 sm:px-6">
    <h2
      class="flex items-center gap-3 font-mono text-sm tracking-widest text-muted-foreground uppercase"
    >
      <span aria-hidden="true" class="h-px w-8 bg-brand"></span>Contact
    </h2>
    <p class="mt-4 max-w-xl text-lg">
      Want to talk hardware, or have a project in mind? My inbox is open.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={`mailto:${site.email}`} class={buttonVariants()}>
        <Mail />
        {site.email}
      </a>
      {
        site.github && (
          <a href={site.github} rel="noopener" class={buttonVariants({ variant: "outline" })}>
            <GitHub />
            GitHub
          </a>
        )
      }
      {
        site.linkedin && (
          <a href={site.linkedin} rel="noopener" class={buttonVariants({ variant: "outline" })}>
            <LinkedIn />
            LinkedIn
          </a>
        )
      }
      {
        site.resume && (
          <a href={site.resume} class={buttonVariants({ variant: "outline" })}>
            <FileText />
            Resume
          </a>
        )
      }
    </div>
  </section>
</Base>
