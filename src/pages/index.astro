---
import { getCollection } from "astro:content";
import Base from "@/layouts/Base.astro";
import { ProjectCard } from "@/components/ProjectCard";
import { buttonVariants } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import GitHub from "@/components/icons/GitHub.astro";
import LinkedIn from "@/components/icons/LinkedIn.astro";
import Mail from "@/components/icons/Mail.astro";
import FileText from "@/components/icons/FileText.astro";
import { site } from "@/lib/site";

const projects = (await getCollection("projects")).sort(
  (a, b) =>
    Number(b.data.featured) - Number(a.data.featured) ||
    b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base>
  <!-- Hero -->
  <section class="mx-auto w-full max-w-5xl px-4 pt-20 pb-16 sm:px-6 sm:pt-28">
    <p class="font-mono text-sm text-muted-foreground">{site.role}</p>
    <h1 class="mt-3 max-w-2xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl">
      <span id="typed">Hi, I'm {site.name}.</span>
    </h1>
    <script is:inline>
      // Typewriter effect for the hero heading. The full text is in the HTML
      // (SEO / no-JS safe); this just replays it. Respects reduced motion.
      (() => {
        const el = document.getElementById("typed");
        if (!el || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const text = el.textContent;
        el.textContent = "";
        el.classList.add("typing");
        let i = 0;
        const tick = () => {
          el.textContent = text.slice(0, ++i);
          if (i < text.length) setTimeout(tick, 60);
          else setTimeout(() => el.classList.remove("typing"), 1200);
        };
        setTimeout(tick, 300);
      })();
    </script>
    <p class="mt-4 max-w-xl text-lg text-muted-foreground">{site.tagline}</p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="#projects" class={buttonVariants()}>View projects</a>
      <a href={`mailto:${site.email}`} class={buttonVariants({ variant: "outline" })}>
        <Mail />
        Get in touch
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6">
    <h2 class="text-sm font-semibold tracking-widest text-muted-foreground uppercase">About</h2>
    <div class="mt-4 max-w-2xl space-y-4 leading-7 text-foreground/90">
      <p>
        I spend most of my time designing mechanisms and hardware — from robotics
        drivetrain components to input devices. Everything on this site was modeled in
        CAD, and most projects include an interactive 3D view of the real assembly.
      </p>
      <p>
        <!-- TODO: personalize this section -->
        Tools I reach for: Onshape and Fusion 360 for mechanical design, KiCad for
        electronics, and a 3D printer for everything in between.
      </p>
    </div>
  </section>

  <Separator className="mx-auto max-w-5xl" />

  <!-- Projects -->
  <section id="projects" class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6">
    <h2 class="text-sm font-semibold tracking-widest text-muted-foreground uppercase">
      Projects
    </h2>
    <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map(({ id, data }) => (
          <ProjectCard
            href={`/projects/${id}/`}
            title={data.title}
            summary={data.summary}
            tags={data.tags}
            poster={data.poster}
            hasModel={Boolean(data.model)}
          />
        ))
      }
    </div>
  </section>

  <Separator className="mx-auto max-w-5xl" />

  <!-- Contact -->
  <section id="contact" class="mx-auto w-full max-w-5xl px-4 py-16 sm:px-6">
    <h2 class="text-sm font-semibold tracking-widest text-muted-foreground uppercase">
      Contact
    </h2>
    <p class="mt-4 max-w-xl text-lg">
      Want to talk hardware, or have a project in mind? My inbox is open.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={`mailto:${site.email}`} class={buttonVariants()}>
        <Mail />
        {site.email}
      </a>
      {
        site.github && (
          <a href={site.github} rel="noopener" class={buttonVariants({ variant: "outline" })}>
            <GitHub />
            GitHub
          </a>
        )
      }
      {
        site.linkedin && (
          <a href={site.linkedin} rel="noopener" class={buttonVariants({ variant: "outline" })}>
            <LinkedIn />
            LinkedIn
          </a>
        )
      }
      {
        site.resume && (
          <a href={site.resume} class={buttonVariants({ variant: "outline" })}>
            <FileText />
            Resume
          </a>
        )
      }
    </div>
  </section>
</Base>
